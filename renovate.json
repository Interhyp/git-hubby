{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [":semanticCommitTypeAll(fix)"],
  "packageRules": [
    {
      "matchPackageNames": ["k8s.io/**", "sigs.k8s.io/**", "github.com/onsi/**"],
      "enabled": false
    },
    {
      "matchManagers": [
        "github-actions",
        "npm",
        "mise"
      ],
      "semanticCommitType": "ci"
    },
    {
      "matchManagers": [
        "devcontainer"
      ],
      "semanticCommitType": "chore"
    }
  ],
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ]
}
